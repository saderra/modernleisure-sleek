{%  comment %}
Custom section developed by Aneurin Barker Snook <aneurin@aneur.in> for Saderra <corinne@saderra.com> Modern Leisure.
{% endcomment %}
{{ 'section-card-images.css' | asset_url | stylesheet_tag }}
{{ 'ml-alt-images.css' | asset_url | stylesheet_tag }}
<script src="{{ 'card-images.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop = section.settings.columns_desktop
  assign columns_tablet = columns_desktop

  assign enable_slider = section.settings.enable_slider

  #if section.blocks.size <= columns_desktop
  #  assign enable_slider = false
  #endif

  assign has_richtext = false
  if section.settings.heading != blank or section.settings.description != blank or section.settings.subheading != blank
    assign has_richtext = true
  endif

  assign header_empty = true
  if has_richtext or enable_slider
    assign header_empty = false
  endif

  assign header_alignment = settings.section_header_alignment
  assign header_alignment_mobile = settings.section_header_alignment_mobile
  if header_alignment_mobile == 'inherit'
    assign header_alignment_mobile = header_alignment
  endif

  assign motion_delay = 50
%}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}
<script type="application/json" id="ml-alt-images-{{ product.id }}-data">
{
  "{{ product.id }}": {
    "alternative_images": []
  }{% if product.variants.size > 0 %},{% endif %}
  {% for v in product.variants %}
  "{{ v.id }}": {
    "alternative_images": {{ v.metafields.custom.alternative_images.value | json }}
  }{% unless forloop.last %},{% endunless %}
  {%  endfor  %}
}
</script>
<script type="application/javascript">
function AlternativeImageHtml(imageUrl) {
  return `
<div class="card-media card-media--content-{{ section.settings.content_position }} card-media--{{ section.settings.content_spacing }} blocks-radius relative overflow-hidden color-{{ section.settings.color_scheme }} hover-wrapper">
  <div class="overflow-hidden block w-full h-full">
    <motion-element class="block h-full" data-motion="zoom-out-sm">
      <picture
        class="card-media__media media-wrapper"
        style="--aspect-ratio: {{ section.settings.image_ratio }}; --aspect-ratio-mobile: {{ section.settings.image_ratio }};"
      >
        <img
          src="${imageUrl}"
          class="motion-reduce absolute inset-0 w-full h-full hover-scale-up"
        />
      </picture>
    </motion-element>
  </div>
</div>
`
}

function getVariantAlternativeImages(variantId) {
  try {
    const el = document.getElementById('ml-alt-images-{{ product.id }}-data')
    if (!el) throw new Error('unable to find alternative images data')

    const data = JSON.parse(el.textContent)
    return data?.[variantId]?.alternative_images || []
  }
  catch(err) {
    console.error(err)
    return []
  }
}

function updateProductAlternativeImages(variantId) {
  const el = document.querySelector('#ml-alt-images-{{ product.id }} [rel="alternative_images"]')
  if (!el) {
    console.error(new Error('unable to find container element'))
    return
  }

  const alternativeImages = getVariantAlternativeImages(variantId).map(AlternativeImageHtml).map(html => {
    const parent = document.createElement('div')
    parent.innerHTML = html
    const innerParent = parent.querySelector('div')
    return innerParent
  })
  if (alternativeImages.length < 1) return
 
  while (el.firstChild) {
    el.removeChild(el.firstChild)
  }

  for (const image of alternativeImages) {
    el.appendChild(image)
  }

  /*
  const container = document.querySelector('#ml-alt-images-{{product.id}} card-images')
  if (!container) {
    console.error(new Error('unable to find card-images element'))
    return
  }

  container.style.removeProperty('--item-height')
  container.calcItemMinHeight()
  */
}

document.querySelector('.product-variant-id')?.addEventListener('change', function() {
  updateProductAlternativeImages(this.value)
})

document.addEventListener('readystatechange', function(event) {
  if (event.target.readyState === 'interactive') {
    const input = document.querySelector('.product-variant-id')
    if (input) {
      updateProductAlternativeImages(input.value)
    }
  }
})
</script>

<div
  id="ml-alt-images-{{ product.id }}"
  class="section section-{{ section.id }} section--padding card-images{% if section.settings.enable_equal_height %} card-images--equal-height{% endif %}{% if enable_slider %} card-images--slider{% endif %} color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="section__wrapper">
      {%- unless header_empty -%}
        <div class="section__header{% if enable_slider %} md:flex justify-between gap-6{% endif %}">
          {% if has_richtext %}
            <div class="rich-text{% if enable_slider %} md:text-left{% else %} md:text-{{ header_alignment }}{% endif %} text-{{ header_alignment_mobile }}">
              {% if section.settings.subheading != blank %}
                <motion-element
                  class="block rich-text__subheading"
                  data-motion="fade-up"
                  data-motion-delay="{{ motion_delay }}"
                >
                  {{- section.settings.subheading -}}
                </motion-element>
                {%- assign motion_delay = motion_delay | plus: 50 -%}
              {% endif %}
              {% if section.settings.heading != blank %}
                <h2 class="rich-text__heading inline-richtext overflow-hidden {{ section.settings.heading_size }}">
                  <motion-element class="block" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
                    {% render 'highlight-text',
                      text: section.settings.heading,
                      style: section.settings.heading_highlight_style
                    %}
                  </motion-element>
                </h2>
                {%- assign motion_delay = motion_delay | plus: 50 -%}
              {% endif %}
              {% if section.settings.description != blank %}
                <motion-element
                  data-motion="fade-up"
                  data-motion-delay="{{ motion_delay }}"
                  class="block rich-text__text rte {{ section.settings.description_size }}"
                >
                  {{- section.settings.description -}}
                </motion-element>
                {%- assign motion_delay = motion_delay | plus: 50 -%}
              {% endif %}
            </div>
          {% endif %}

          {% if enable_slider %}
            <motion-element
              data-motion="fade-up"
              data-motion-delay="{{ motion_delay }}"
              class="swiper-controls hidden md:inline-flex"
            >
              <button
                type="button"
                class="swiper-btn-prev btn btn--icon-circle shrink-0"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
              >
                {%- render 'icon-slider-prev' -%}
              </button>
              <button
                type="button"
                class="swiper-btn-next btn btn--icon-circle shrink-0"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
              >
                {%- render 'icon-slider-next' -%}
              </button>
            </motion-element>
            {%- assign motion_delay = motion_delay | plus: 50 -%}
          {% endif %}
        </div>
      {%- endunless -%}
      <motion-element class="section__content block" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
        <card-images
          class="block f-grid--gap-{{ section.settings.column_gap_mobile }} md:f-grid--gap-{{ section.settings.column_gap }}{% if enable_slider %} swiper{% endif %}"
          data-section-id="{{ section.id }}"
          {% if enable_slider %}
            data-enable-slider="true"
            data-items="{{ columns_desktop }}"
            data-tablet-items="{{ columns_tablet }}"
          {% endif %}
        >
          <div class="card-images__items f-grid f-grid-{{ columns_mobile_int }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols{% if enable_slider %} swiper-wrapper{% endif %}" rel="alternative_images"></div>
          <div class="swiper-pagination swiper-pagination-bullets-animate md:hidden"></div>
        </card-images>
      </motion-element>
    </div>
  </div>
</div>

