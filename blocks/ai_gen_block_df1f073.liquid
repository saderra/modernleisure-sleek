{% doc %}
  @prompt
    two column top bar with text in the left block aligned left and text in the right block aligned right. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-top-bar-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-top-bar-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    gap: 20px;
  }

  .ai-top-bar-left-{{ ai_gen_id }} {
    flex: 1;
    text-align: left;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
  }

  .ai-top-bar-right-{{ ai_gen_id }} {
    flex: 1;
    text-align: right;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-top-bar-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      text-align: {{ block.settings.mobile_text_alignment }};
      gap: 10px;
    }

    .ai-top-bar-left-{{ ai_gen_id }},
    .ai-top-bar-right-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }

    .ai-top-bar-right-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<div class="ai-top-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-top-bar-container-{{ ai_gen_id }}">
    <div class="ai-top-bar-left-{{ ai_gen_id }}">
      {% if block.settings.left_text != blank %}
        {{ block.settings.left_text }}
      {% else %}
        Left text
      {% endif %}
    </div>
    <div class="ai-top-bar-right-{{ ai_gen_id }}">
      {% if block.settings.right_text != blank %}
        {{ block.settings.right_text }}
      {% else %}
        Right text
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two column top bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "left_text",
      "label": "Left text",
      "default": "<p>Free shipping on orders over $100</p>"
    },
    {
      "type": "richtext",
      "id": "right_text",
      "label": "Right text",
      "default": "<p>Contact us: (555) 123-4567</p>"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Layout",
      "options": [
        {
          "value": "row",
          "label": "Row"
        },
        {
          "value": "column",
          "label": "Column"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Two column top bar"
    }
  ]
}
{% endschema %}
