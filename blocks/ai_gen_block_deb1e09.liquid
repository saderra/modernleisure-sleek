            </div>

            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-additional-picture-1-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Additional picture 1
              </label>
              <input
                type="file"
                id="ai-contact-additional-picture-1-{{ ai_gen_id }}"
                name="{{ block.settings.additional_picture_1_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__file-input-{{ ai_gen_id }}"
                accept="image/*"
              >
            </div>

            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-additional-picture-2-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Additional picture 2
              </label>
              <input
                type="file"
                id="ai-contact-additional-picture-2-{{ ai_gen_id }}"
                name="{{ block.settings.additional_picture_2_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__file-input-{{ ai_gen_id }}"
                accept="image/*"
              >
            </div>

            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-additional-picture-3-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Additional picture 3
              </label>
              <input
                type="file"
                id="ai-contact-additional-picture-3-{{ ai_gen_id }}"
                name="{{ block.settings.additional_picture_3_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__file-input-{{ ai_gen_id }}"
                accept="image/*"
              >
            </div>
          </div>

          <div class="ai-contact-form__conditional-fields-{{ ai_gen_id }}" data-reason="Product Question - Please include Part number or Description">
            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-message-product-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Message
              </label>
              <textarea
                id="ai-contact-message-product-{{ ai_gen_id }}"
                name="{{ block.settings.message_field_name }}"
                class="ai-contact-form__textarea-{{ ai_gen_id }}"
              ></textarea>
            </div>
          </div>

          <div class="ai-contact-form__conditional-fields-{{ ai_gen_id }}" data-reason="Order/Tracking Information">
            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-order-number-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Order number
              </label>
              <input
                type="text"
                id="ai-contact-order-number-{{ ai_gen_id }}"
                name="{{ block.settings.order_number_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }}"
              >
            </div>

            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-message-order-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Message
              </label>
              <textarea
                id="ai-contact-message-order-{{ ai_gen_id }}"
                name="{{ block.settings.message_field_name }}"
                class="ai-contact-form__textarea-{{ ai_gen_id }}"
              ></textarea>
