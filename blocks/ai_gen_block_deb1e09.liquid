</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.reasonSelect = null;
        this.conditionalFields = [];
        this.form = null;
        this.formWrapper = null;
        this.successMessage = null;
        this.errorMessage = null;
        this.submitButton = null;
        this.formActionUrl = '{{ block.settings.form_action_url }}';
      }

      connectedCallback() {
        this.reasonSelect = this.querySelector('[data-reason-select]');
        this.conditionalFields = this.querySelectorAll('.ai-contact-form__conditional-fields-{{ ai_gen_id }}');
        this.form = this.querySelector('[data-contact-form]');
        this.formWrapper = this.querySelector('[data-form-wrapper]');
        this.successMessage = this.querySelector('[data-success-message]');
        this.errorMessage = this.querySelector('[data-error-message]');
        this.submitButton = this.querySelector('[data-submit-button]');

        if (this.reasonSelect) {
          this.reasonSelect.addEventListener('change', this.handleReasonChange.bind(this));
        }

        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleReasonChange(event) {
        const selectedReason = event.target.value;

        if (selectedReason === 'Become Dealer') {
          window.open('https://commerce.byallen.com/customer/account/login', '_blank');
          this.form.reset();
          this.hideAllConditionalFields();
          return;
        }

        this.hideAllConditionalFields();

        this.conditionalFields.forEach(fieldGroup => {
          const reason = fieldGroup.getAttribute('data-reason');
          if (reason === selectedReason) {
            fieldGroup.classList.add('active');
          }
        });
      }

      hideAllConditionalFields() {
        this.conditionalFields.forEach(fieldGroup => {
          fieldGroup.classList.remove('active');
          const inputs = fieldGroup.querySelectorAll('input, textarea, select');
          inputs.forEach(input => {
            input.value = '';
          });
        });
      }

      async handleSubmit(event) {
        event.preventDefault();

        if (!this.formActionUrl) {
          this.showError('{{ block.settings.error_message }}');
          return;
        }

        this.hideError();
        this.submitButton.disabled = true;
        this.submitButton.textContent = 'Sending...';

        try {
          const formData = new FormData(this.form);
          
          const response = await fetch(this.formActionUrl, {
            method: 'POST',
            body: formData
          });

          if (response.ok && response.status >= 200 && response.status < 300) {
            this.showSuccess();
          } else {
            this.showError('{{ block.settings.error_message }}');
          }
        } catch (error) {
          this.showError('{{ block.settings.error_message }}');
        } finally {
          this.submitButton.disabled = false;
          this.submitButton.textContent = '{{ block.settings.button_text }}';
        }
      }

      showSuccess() {
        this.formWrapper.classList.add('hidden');
        this.successMessage.style.display = 'block';
      }

      showError(message) {
        this.errorMessage.textContent = message;
        this.errorMessage.style.display = 'block';
      }

      hideError() {
        this.errorMessage.style.display = 'none';
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

