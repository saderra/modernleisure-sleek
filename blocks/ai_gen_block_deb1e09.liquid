              <label for="ai-contact-issue-description-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Description of the issue
              </label>
              <textarea
                id="ai-contact-issue-description-{{ ai_gen_id }}"
                name="{{ block.settings.issue_description_field_name }}"
                class="ai-contact-form__textarea-{{ ai_gen_id }}"
              ></textarea>
            </div>

            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-receipt-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Copy of the receipt
              </label>
              <input
                type="file"
                id="ai-contact-receipt-{{ ai_gen_id }}"
                name="{{ block.settings.receipt_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__file-input-{{ ai_gen_id }}"
