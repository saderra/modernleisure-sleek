            <div class="ai-contact-form__field-{{ ai_gen_id }}">
              <label for="ai-contact-item-number-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
                Item number
              </label>
              <input
                type="text"
                id="ai-contact-item-number-{{ ai_gen_id }}"
                name="{{ block.settings.item_number_field_name }}"
                class="ai-contact-form__input-{{ ai_gen_id }}"
              >
